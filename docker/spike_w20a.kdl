// W2.0a/b probe layout — two tabs with distinct, continuously-CHANGING content
// (a counter, no screen-clear) so each render tick is a genuine grid change
// (zellij dedupes identical renders, so static content yields no updates).
layout {
    tab name="alpha" focus=true {
        pane command="bash" {
            args "-c" "i=0; while true; do echo \"ZZZ_ALPHA_ZZZ line $i\"; i=$((i+1)); sleep 0.3; done"
        }
    }
    tab name="bravo" {
        pane command="bash" {
            args "-c" "i=0; while true; do echo \"ZZZ_BRAVO_ZZZ line $i\"; i=$((i+1)); sleep 0.3; done"
        }
    }
}
